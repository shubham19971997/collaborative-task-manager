// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

// Commands to run and push prisma schema
// 1. npx prisma generate
// 2. npx prisma db push

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}
// ─── AUTH ─────────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  avatarUrl    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  memberships   Member[]
  assignedCards Card[]         @relation("CardAssignee")
  activities    Activity[]
  refreshTokens RefreshToken[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique  // stored as bcrypt hash
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

// ─── WORKSPACE ────────────────────────────────────────────────────────────────

model Workspace {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique  // URL-safe identifier e.g. "my-startup"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  members Member[]
  boards  Board[]

  @@map("workspaces")
}

// Join table: User ↔ Workspace with a Role
model Member {
  id          String   @id @default(cuid())
  role        Role     @default(MEMBER)
  createdAt   DateTime @default(now())

  userId      String
  workspaceId String

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId]) // One membership per user per workspace
  @@map("members")
}

// ─── BOARD ────────────────────────────────────────────────────────────────────

model Board {
  id          String   @id @default(cuid())
  title       String
  description String?
  coverColor  String?  // hex color for board cover UI
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  columns Column[]

  @@map("boards")
}

model Column {
  id        String   @id @default(cuid())
  title     String
  position  Float    // fractional indexing — avoids reordering all siblings on a move
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  boardId String
  board   Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)

  cards Card[]

  @@map("columns")
}

// ─── CARD ─────────────────────────────────────────────────────────────────────

model Card {
  id          String    @id @default(cuid())
  title       String
  description String?
  position    Float     // fractional indexing within a column
  dueDate     DateTime?
  coverImage  String?   // Cloudinary URL
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  columnId   String
  assigneeId String?

  column   Column @relation(fields: [columnId], references: [id], onDelete: Cascade)
  assignee User?  @relation("CardAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  labels     CardLabel[]
  activities Activity[]

  @@map("cards")
}

// ─── LABEL ────────────────────────────────────────────────────────────────────

model Label {
  id    String @id @default(cuid())
  name  String
  color String // hex e.g. "#F97316"

  cards CardLabel[]

  @@map("labels")
}

// Explicit many-to-many join table for Card ↔ Label
model CardLabel {
  cardId  String
  labelId String

  card  Card  @relation(fields: [cardId], references: [id], onDelete: Cascade)
  label Label @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([cardId, labelId])
  @@map("card_labels")
}

// ─── ACTIVITY LOG ─────────────────────────────────────────────────────────────

model Activity {
  id        String   @id @default(cuid())
  action    String   // e.g. "moved card to Done", "changed due date to Jan 5"
  createdAt DateTime @default(now())

  userId String
  cardId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@map("activities")
}
